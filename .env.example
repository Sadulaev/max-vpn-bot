# Application
PORT=3000
NODE_ENV=production
BASE_URL=https://api.your-domain.ru

# Authentication (JWT для admin panel)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here
JWT_SECRET=your-jwt-secret-key-minimum-32-characters-long

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=vpn
DB_PASSWORD=your_db_password
DB_NAME=hyper_vpn

# Telegram Bot (User Bot для взаимодействия с пользователями)
TG_USER_BOT_TOKEN=your_telegram_bot_token_here
# ID канала для уведомлений (формат: -100xxxxxxxxxx)
TG_NOTIFICATION_CHANNEL_ID=

# MAX Bot (мессенджер для отправки сообщений пользователям)
# Токен MAX Bot API - получить на https://max.im/developer
# Связывается с пользователями через MAX мессенджер
MAX_BOT_TOKEN=your_max_bot_token_here

# Robokassa
ROBOKASSA_MERCHANT_ID=your_merchant_id
ROBOKASSA_PASSWORD_1=your_password_1
ROBOKASSA_PASSWORD_2=your_password_2
# true = тестовый режим (деньги не списываются), false = боевой
ROBOKASSA_TEST_MODE=true

# Google Sheets (для логирования продаж)
GOOGLE_SHEETS_ID=your_spreadsheet_id
GOOGLE_SA_CLIENT_EMAIL=your_service_account@project.iam.gserviceaccount.com
# Приватный ключ сервисного аккаунта (вставлять как одну строку с \n)
GOOGLE_SA_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# ─── Remnawave ────────────────────────────────────────────────────────────────
# Адрес Remnawave API (без слеша на конце)
REMNAWAVE_API_URL=https://remnawave.your-domain.ru
# API-токен из Remnawave UI → Settings → API Tokens
REMNAWAVE_API_TOKEN=your_remnawave_api_token

# UUID внутренних сквадов (Internal Squads) из Remnawave UI → Squads
# Сквад Standard: назначить inbound'ы обычных серверов
REMNAWAVE_STANDARD_SQUAD_UUID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Сквад Anti-Throttle: назначить inbound'ы серверов с антиблокировкой
REMNAWAVE_ANTI_THROTTLING_SQUAD_UUID=yyyyyyyy-yyyy-yyyy-yyyy-yyyyyyyyyyyy

# URL страницы подписки для пользователя (фронтенд, опционально)
# Если не задан — используется REMNAWAVE_API_URL/api/sub/{shortUuid}/info
REMNAWAVE_SUB_PAGE_URL=

# ─── Santa Chat (AI чат на сайте) ────────────────────────────────────────────
# URL AI API (по умолчанию OpenAI)
SANTA_AI_API_URL=https://api.openai.com/v1/chat/completions
# Ваш API-ключ (sk-...)
SANTA_AI_API_KEY=sk-...
# Модель (gpt-4o-mini — дёшево и быстро, gpt-4o — лучше качество)
SANTA_AI_MODEL=gpt-4o-mini
# Лимит сообщений на free-tier в сутки на одну сессию
SANTA_DAILY_LIMIT=10
# JWT-секрет для авторизации пользователей сайта (отдельный от admin JWT_SECRET)
SITE_JWT_SECRET=site-secret-change-me-to-random-64-chars
