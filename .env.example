# ─── Application ─────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
# Публичный URL бэкенда (используется для регистрации webhook)
BASE_URL=https://api.your-domain.ru

# ─── Authentication (JWT для admin panel) ─────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here
JWT_SECRET=your-jwt-secret-key-minimum-32-characters-long

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=vpn
DB_PASSWORD=your_db_password
DB_NAME=max_vpn

# ─── MAX Bot ──────────────────────────────────────────────────────────────────
# Токен MAX Bot API — получить на https://max.im/developer
MAX_BOT_TOKEN=your_max_bot_token_here
# Базовый URL MAX API (по умолчанию https://platform-api2.max.ru)
MAX_API_URL=https://platform-api2.max.ru
# Секрет для верификации webhook-запросов (любая случайная строка)
MAX_WEBHOOK_SECRET=your_webhook_secret_here
# Username бота в MAX (без @)
MAX_BOT_USERNAME=your_bot_username
# Ссылка для реферальной системы (обычно ссылка на бота: https://max.ru/d.../bot)
MAX_REFERRAL_BASE_URL=https://max.ru/d201502199404_bot

# ─── Bot настройки ────────────────────────────────────────────────────────────
# Ссылка на профиль поддержки в MAX (формат: https://max.ru/PHONE или https://max.ru/username)
BOT_SUPPORT_CONTACT=https://max.ru/79166136466
# Ссылка на канал проекта в MAX (опционально)
BOT_CHANNEL_LINK=

# ─── Freekassa (платёжная система) ────────────────────────────────────────────
FREEKASSA_SHOP_ID=your_shop_id
FREEKASSA_SECRET_WORD=your_secret_word_1
FREEKASSA_SECRET_WORD2=your_secret_word_2
FREEKASSA_API_KEY=your_api_key
# IP-адрес сервера (для проверки IP в уведомлениях от Freekassa)
SERVER_IP=your_server_ip

# ─── Remnawave ────────────────────────────────────────────────────────────────
# Адрес Remnawave API (без слеша на конце)
REMNAWAVE_API_URL=https://remnawave.your-domain.ru
# API-токен из Remnawave UI → Settings → API Tokens
REMNAWAVE_API_TOKEN=your_remnawave_api_token

# UUID внутренних сквадов (Internal Squads) из Remnawave UI → Squads
# Сквад Standard: назначить inbound'ы обычных серверов
REMNAWAVE_STANDARD_SQUAD_UUID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Сквад Anti-Throttle: назначить inbound'ы серверов с антиблокировкой
REMNAWAVE_ANTI_THROTTLING_SQUAD_UUID=yyyyyyyy-yyyy-yyyy-yyyy-yyyyyyyyyyyy

# URL страницы подписки для пользователя (фронтенд, опционально)
# Если не задан — используется REMNAWAVE_API_URL/api/sub/{shortUuid}/info
REMNAWAVE_SUB_PAGE_URL=

# ─── Notifications ────────────────────────────────────────────────────────────
# ID канала Telegram для уведомлений (формат: -100xxxxxxxxxx), опционально
TG_NOTIFICATION_CHANNEL_ID=
